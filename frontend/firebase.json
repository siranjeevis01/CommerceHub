{
  "hosting": {
    "public": "dist/shell",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=2592000" }
        ]
      },
      {
        "source": "**/*.@(woff|woff2|ttf|eot)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/remoteEntry.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-XSS-Protection", "value": "1; mode=block" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-XSS-Protection", "value": "1; mode=block" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/admin/remoteEntry.js", "destination": "/admin/remoteEntry.js" },
      { "source": "/admin/assets/**", "destination": "/admin/assets/**" },
      { "source": "/admin/**", "destination": "/admin/index.html" },
      { "source": "/vendor/remoteEntry.js", "destination": "/vendor/remoteEntry.js" },
      { "source": "/vendor/assets/**", "destination": "/vendor/assets/**" },
      { "source": "/vendor/**", "destination": "/vendor/index.html" },
      { "source": "/storefront/remoteEntry.js", "destination": "/storefront/remoteEntry.js" },
      { "source": "/storefront/assets/**", "destination": "/storefront/assets/**" },
      { "source": "/storefront/**", "destination": "/storefront/index.html" },
      { "source": "/account/**", "destination": "/index.html" },
      { "source": "/dashboard/**", "destination": "/index.html" },
      { "source": "/store/**", "destination": "/index.html" },
      { "source": "/products/**", "destination": "/index.html" },
      { "source": "/cart/**", "destination": "/index.html" },
      { "source": "/checkout/**", "destination": "/index.html" },
      { "source": "/orders/**", "destination": "/index.html" },
      { "source": "/auth/**", "destination": "/index.html" },
      { "source": "/api/**", "destination": "/api/**" },
      { "source": "/assets/**", "destination": "/assets/**" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}

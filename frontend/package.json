{
  "name": "commercehub-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "build:shell": "ng build shell",
    "build:admin": "ng build admin",
    "build:vendor": "ng build vendor",
    "build:storefront": "ng build storefront",
    "build:all": "ng build admin && ng build vendor && ng build storefront && ng build shell && node -e \"const fs=require('fs');['admin','vendor','storefront'].forEach(d=>{fs.cpSync('dist/'+d,'dist/shell/'+d,{recursive:true,force:true});console.log('Copied',d)})\"",
    "serve:shell": "ng serve shell",
    "serve:admin": "ng serve admin",
    "serve:vendor": "ng serve vendor",
    "serve:storefront": "ng serve storefront",
    "test": "ng test",
    "lint": "ng lint",
    "analyze": "ng build shell --stats-json && webpack-bundle-analyzer dist/shell/stats.json"
  },
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@microsoft/signalr": "^10.0.0",
    "@popperjs/core": "^2.11.0",
    "bootstrap": "^5.3.0",
    "chart.js": "^4.4.0",
    "ngx-currency": "^19.0.0",
    "ngx-pagination": "^6.0.3",
    "ngx-toastr": "^19.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-architects/module-federation": "^20.0.0",
    "@angular-devkit/build-angular": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@angular/localize": "^20.0.0",
    "concurrently": "^8.2.0",
    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ngx-build-plus": "^20.0.0",
    "protractor": "~7.0.0",
    "ts-node": "~10.9.0",
    "tslint": "~6.1.0",
    "typescript": "~5.9.0",
    "webpack": "5.105.0",
    "webpack-bundle-analyzer": "^4.10.0",
    "webpack-cli": "^5.0.0",
    "webpack-merge": "^6.0.0"
  }
}

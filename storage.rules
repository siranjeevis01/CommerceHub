rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /products/{productId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'vendor' || request.auth.token.role == 'admin';
    }
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
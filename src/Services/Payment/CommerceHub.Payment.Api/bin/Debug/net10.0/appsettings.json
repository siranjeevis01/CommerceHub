{
  "Logging": { "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" } },
  "ConnectionStrings": { "DefaultConnection": "${PAYMENT_DB_CONNECTION}" },
  "PaymentGateways": {
    "Stripe": { "SecretKey": "${STRIPE_SECRET_KEY}", "WebhookSecret": "${STRIPE_WEBHOOK_SECRET}" },
    "Razorpay": { "KeyId": "${RAZORPAY_KEY_ID}", "KeySecret": "${RAZORPAY_KEY_SECRET}", "WebhookSecret": "${RAZORPAY_WEBHOOK_SECRET}" }
  },
  "AllowedHosts": "*"
}

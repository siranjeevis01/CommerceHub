# TiDB Cloud (MySQL-compatible)
DB_ROOT_PASSWORD=your_tidb_root_password

# All TiDB connection strings (append SSL params)
# Format: Server=gateway01.us-west-2.prod.aws.tidbcloud.com;Port=4000;Database=commercehub_<module>;User=<user>.root;Password=<password>;SslMode=Required;AllowPublicKeyRetrieval=true
IDENTITY_DB_CONNECTION=Server=your-tidb-host;Port=4000;Database=commercehub_identity;User=your_user.root;Password=your_password;SslMode=Required;AllowPublicKeyRetrieval=true
PRODUCT_DB_CONNECTION=Server=your-tidb-host;Port=4000;Database=commercehub_product;User=your_user.root;Password=your_password;SslMode=Required;AllowPublicKeyRetrieval=true
ORDER_DB_CONNECTION=Server=your-tidb-host;Port=4000;Database=commercehub_order;User=your_user.root;Password=your_password;SslMode=Required;AllowPublicKeyRetrieval=true
PAYMENT_DB_CONNECTION=Server=your-tidb-host;Port=4000;Database=commercehub_payment;User=your_user.root;Password=your_password;SslMode=Required;AllowPublicKeyRetrieval=true
VENDOR_DB_CONNECTION=Server=your-tidb-host;Port=4000;Database=commercehub_vendor;User=your_user.root;Password=your_password;SslMode=Required;AllowPublicKeyRetrieval=true
INVENTORY_DB_CONNECTION=Server=your-tidb-host;Port=4000;Database=commercehub_inventory;User=your_user.root;Password=your_password;SslMode=Required;AllowPublicKeyRetrieval=true
NOTIFICATION_DB_CONNECTION=Server=your-tidb-host;Port=4000;Database=commercehub_notification;User=your_user.root;Password=your_password;SslMode=Required;AllowPublicKeyRetrieval=true
CMS_DB_CONNECTION=Server=your-tidb-host;Port=4000;Database=commercehub_cms;User=your_user.root;Password=your_password;SslMode=Required;AllowPublicKeyRetrieval=true
ANALYTICS_DB_CONNECTION=Server=your-tidb-host;Port=4000;Database=commercehub_analytics;User=your_user.root;Password=your_password;SslMode=Required;AllowPublicKeyRetrieval=true
AI_DB_CONNECTION=Server=your-tidb-host;Port=4000;Database=commercehub_ai;User=your_user.root;Password=your_password;SslMode=Required;AllowPublicKeyRetrieval=true

# Redis
REDIS_CONNECTION_STRING=your-redis-host:port,password=your_redis_password

# RabbitMQ (CloudAMQP)
RABBITMQ_HOST=your-rabbitmq-host
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_PASS=your_rabbitmq_password
RABBITMQ_VHOST=your_vhost

# JWT (base64-encoded, minimum 32 bytes)
JWT_KEY=your_base64_encoded_jwt_key_minimum_32_bytes_here
JWT_ISSUER=CommerceHub
JWT_AUDIENCE=CommerceHubClient

# CORS
ALLOWED_ORIGINS=https://your-app.web.app,https://your-mobile-app.web.app,http://localhost:4200

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
Smtp__EnableSsl=true

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# UPI
UPI_ID=your_upi_id@provider
UPI_MERCHANT_NAME=CommerceHub

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Seed
SEED__ENABLED=true
SEED__ADMINEMAIL=admin@yourdomain.com
SEED__ADMINPASSWORD=YourSecurePassword123!

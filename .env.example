# Infrastructure
DB_ROOT_PASSWORD=rootpassword
REDIS_PASSWORD=redispass
REDIS_INSTANCE_NAME=CommerceHub_
REDIS_DEFAULT_CACHE_MINUTES=5
POSTGRES_PASSWORD=postgrespass
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_PORT=5672

# Service Database Connections
IDENTITY_DB_CONNECTION=server=localhost;database=commercehub_identity;user=root;password=rootpassword
PRODUCT_DB_CONNECTION=server=localhost;database=commercehub_product;user=root;password=rootpassword
ORDER_DB_CONNECTION=server=localhost;database=commercehub_order;user=root;password=rootpassword
PAYMENT_DB_CONNECTION=server=localhost;database=commercehub_payment;user=root;password=rootpassword
VENDOR_DB_CONNECTION=server=localhost;database=commercehub_vendor;user=root;password=rootpassword
INVENTORY_DB_CONNECTION=server=localhost;database=commercehub_inventory;user=root;password=rootpassword
CMS_DB_CONNECTION=server=localhost;database=commercehub_cms;user=root;password=rootpassword
AI_DB_CONNECTION=server=localhost;database=commercehub_ai;user=root;password=rootpassword
NOTIFICATION_DB_CONNECTION=server=localhost;database=commercehub_notification;user=root;password=rootpassword
ANALYTICS_DB_CONNECTION=Host=localhost;Database=commercehub_analytics;Username=postgres;Password=postgrespass

# AI Agent
GEMINI_API_KEY=your-gemini-api-key-here
PRODUCT_SERVICE_URL=http://localhost:5002

# Infrastructure Hosts
RABBITMQ_HOST=localhost
REDIS_CONNECTION_STRING=localhost:6379,password=redispass
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=

# JWT
JWT_KEY=ThisIsA-Development-JWT-Key-ChangeMe123!
JWT_ISSUER=CommerceHub
JWT_AUDIENCE=CommerceHubClient
JWT_EXPIRY_HOURS=24

# CORS
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8100,http://localhost:3000

# Seed
SEED__ENABLED=true
SEED__ADMINEMAIL=admin@commercehub.com
SEED__ADMINPASSWORD=Admin@1234

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@commercehub.com
SMTP_FROM_NAME=CommerceHub

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=rzp_webhook_secret_placeholder

# Storage (local / s3 / azure)
STORAGE_PROVIDER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=commercehub-assets
AWS_REGION=us-east-1
AWS_CLOUDFRONT_URL=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=commercehub-assets

# API & Debug
API_BASE_URL=http://localhost:5000
ENABLE_SWAGGER=true
ENABLE_HANGFIRE=true
DETAILED_ERRORS=true
ADMIN_EMAIL=admin@commercehub.com

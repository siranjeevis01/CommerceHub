{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "frontend/dist/shell",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/admin/remoteEntry.js", "destination": "/admin/remoteEntry.js" },
      { "source": "/vendor/remoteEntry.js", "destination": "/vendor/remoteEntry.js" },
      { "source": "/storefront/remoteEntry.js", "destination": "/storefront/remoteEntry.js" },
      { "source": "/admin/**", "destination": "/index.html" },
      { "source": "/vendor/**", "destination": "/index.html" },
      { "source": "/storefront/**", "destination": "/index.html" },
      { "source": "/auth/**", "destination": "/index.html" },
      { "source": "/profile/**", "destination": "/index.html" },
      { "source": "/cart", "destination": "/index.html" },
      { "source": "/home", "destination": "/index.html" },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(css|js|json|woff2|ttf|eot|ico|svg|png|jpg|jpeg|gif|webp)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-XSS-Protection", "value": "1; mode=block" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ]
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  }
}

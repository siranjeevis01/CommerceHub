{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "CommerceHub",
    "Audience": "CommerceHubClient"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/v{version}/identity/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/v{version}/{**catch-all}" }
        ]
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/v{version}/products/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/v{version}/{**catch-all}" }
        ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/v{version}/orders/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/v{version}/{**catch-all}" }
        ]
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": { "Path": "/api/v{version}/cart/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/v{version}/{**catch-all}" }
        ]
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": { "Path": "/api/v{version}/payments/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/v{version}/{**catch-all}" }
        ]
      },
      "vendor-route": {
        "ClusterId": "vendor-cluster",
        "Match": { "Path": "/api/v{version}/vendors/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/v{version}/{**catch-all}" }
        ]
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": { "Path": "/api/v{version}/inventory/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/v{version}/{**catch-all}" }
        ]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/v{version}/notifications/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/v{version}/{**catch-all}" }
        ]
      },
      "cms-route": {
        "ClusterId": "cms-cluster",
        "Match": { "Path": "/api/v{version}/cms/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/v{version}/{**catch-all}" }
        ]
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "Match": { "Path": "/api/v{version}/analytics/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/v{version}/{**catch-all}" }
        ]
      },
      "webhook-route": {
        "ClusterId": "gateway-cluster",
        "Match": { "Path": "/api/webhooks/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/webhooks/{**catch-all}" }
        ]
      },
      "signalr-notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/hubs/notification" }
      },
      "signalr-tracking-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/hubs/tracking" }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-1": { "Address": "http://commercehub-identity:8080/" }
        }
      },
      "product-cluster": {
        "Destinations": {
          "product-1": { "Address": "http://commercehub-product:8080/" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-1": { "Address": "http://commercehub-order:8080/" }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "cart-1": { "Address": "http://commercehub-cart:8080/" }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-1": { "Address": "http://commercehub-payment:8080/" }
        }
      },
      "vendor-cluster": {
        "Destinations": {
          "vendor-1": { "Address": "http://commercehub-vendor:8080/" }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "inventory-1": { "Address": "http://commercehub-inventory:8080/" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-1": { "Address": "http://commercehub-notification:8080/" }
        }
      },
      "cms-cluster": {
        "Destinations": {
          "cms-1": { "Address": "http://commercehub-cms:8080/" }
        }
      },
      "analytics-cluster": {
        "Destinations": {
          "analytics-1": { "Address": "http://commercehub-analytics:8080/" }
        }
      },
      "gateway-cluster": {
        "Destinations": {
          "gateway-1": { "Address": "http://commercehub-gateway:8080/" }
        }
      }
    },
    "RateLimiting": {
      "DefaultPolicy": {
        "Window": "00:01:00",
        "PermitLimit": 100,
        "QueueLimit": 2
      }
    }
  },
  "AllowedHosts": "*"
}
